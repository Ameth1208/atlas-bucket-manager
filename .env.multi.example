# =============================================
# Multi-Instance Configuration Example
# =============================================
# Use this file to configure multiple instances
# with different ports and providers
#
# Usage:
#   cp .env.multi.example .env.multi
#   docker-compose -f docker-compose.multi.yml --env-file .env.multi up -d

# =============================================
# Instance 1 - Port 3001 (MinIO)
# =============================================
ADMIN_USER_1=admin
ADMIN_PASS_1=secure-password-1

MINIO_ENDPOINT_1=minio-server
MINIO_ACCESS_KEY_1=minioadmin
MINIO_SECRET_KEY_1=minioadmin

# =============================================
# Instance 2 - Port 3002 (AWS S3)
# =============================================
ADMIN_USER_2=admin
ADMIN_PASS_2=secure-password-2

AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# =============================================
# Instance 3 - Port 8080 (Cloudflare R2)
# =============================================
ADMIN_USER_3=admin
ADMIN_PASS_3=secure-password-3

R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
